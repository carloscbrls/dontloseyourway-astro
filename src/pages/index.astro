---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Don't Lose Your Way — A Space for Reflection" description="You are not the only one. A reflection space for those who almost gave up — and stayed.">
  
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-glow"></div>
    <div class="hero-content">
      <img src="/logo.png" alt="Don't Lose Your Way" class="hero-logo" width="300" height="75" />
      
      <h1 class="hero-title">You are not the only one.</h1>
      
      <p class="hero-subtitle">A quiet space for reflection.</p>
      <p class="hero-subtitle">Not therapy. Not a fix.</p>
      <p class="hero-subtitle">Just proof that others have stood where you stand.</p>
      
      <div class="hero-ctas">
        <a href="/chapel" class="cta cta-primary">Visit the Chapel</a>
      </div>
      
      <div class="hero-actions">
        <a href="/chapel" class="action-link">I need to breathe</a>
        <a href="/journal" class="action-link">I need to read</a>
        <a href="/podcast" class="action-link">I need to listen</a>
      </div>
    </div>
  </section>

  <!-- Chapel Preview -->
  <section class="section chapel-preview">
    <div class="container">
      <div class="chapel-card">
        <h2 class="chapel-title">Turn Feelings Into Sound</h2>
        <div class="chapel-text">
          <p>Sometimes emotions are hard to explain in normal words.</p>
          <p>Inside the Chapel, visitors can write a few thoughts about what they are feeling. Those words can become phrases, lyrics, or songs that reflect the moment they are living through.</p>
          <p>Some are shared with others.</p>
          <p>Some remain private.</p>
          <p class="chapel-emphasis">But every voice matters.</p>
        </div>
        <a href="/chapel" class="cta cta-primary">Enter the Chapel</a>
      </div>
    </div>
  </section>

  <!-- Why This Matters -->
  <section class="section why-matters">
    <div class="container">
      <h2 class="section-title">Why This Matters</h2>
      <p class="section-lead">Don't Lose Your Way was created for the quiet moments people often face alone — moments of emotional overload, isolation, fear, grief, or inner pressure that can feel impossible to explain.</p>
      <p class="section-lead">This platform exists to offer a pause.</p>
      <p class="section-lead">Through reflections, music, podcasts, anonymous voices, and creative expression, it creates a space where someone can feel seen before they give up, shut down, or lose their way.</p>
      
      <div class="features">
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="feature-title">Emotional Reflection</h3>
          <p class="feature-desc">A place for visitors to slow down, read, breathe, and reconnect with what they are feeling.</p>
        </div>
        
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          </div>
          <h3 class="feature-title">Creative Expression</h3>
          <p class="feature-desc">Through the Chapel experience, feelings can be transformed into words, phrases, lyrics, or songs that give emotion a voice.</p>
        </div>
        
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="feature-title">Community Voice</h3>
          <p class="feature-desc">Anonymous reflections, shared stories, and future audio submissions help visitors understand they are not alone.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Beginning -->
  <section class="section the-beginning">
    <div class="container">
      <div class="beginning-content">
        <h2 class="beginning-title">The Beginning</h2>
        <blockquote class="beginning-quote">
          I wrote a letter I hoped no one would ever have to read.
        </blockquote>
        <p class="beginning-text">I'm still here. And if you're reading this, you are too.</p>
        <p class="beginning-text">This isn't a success story. It's a place to feel less alone.</p>
        <a href="/about" class="cta cta-secondary">Read the full story</a>
      </div>
    </div>
  </section>

  <!-- Support -->
  <section class="section support-section">
    <div class="container">
      <h2 class="section-title">Help This Project Reach Someone Who Needs It</h2>
      <p class="section-lead">Built as a digital storytelling and emotional support platform, Don't Lose Your Way welcomes:</p>
      <ul class="support-list">
        <li>Partnerships with mental health organizations and advocacy groups</li>
        <li>Grants and funding opportunities</li>
        <li>Sponsorships from aligned organizations</li>
        <li>Community collaboration and creative contributions</li>
      </ul>
      <div class="support-ctas">
        <a href="/partners#contact" class="cta cta-primary">Support This Project</a>
        <a href="/partners" class="cta cta-secondary">Partner With Us</a>
      </div>
    </div>
  </section>

  <!-- Bottom logo -->
  <section class="section bottom-logo-section">
    <div class="container" style="text-align:center;">
      <img src="/logo.png" alt="Don't Lose Your Way" width="200" height="50" class="bottom-logo" />
      <p class="bottom-stay">Stay.</p>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 1.25rem 4rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('https://images.pexels.com/photos/1252890/pexels-photo-1252890.jpeg?auto=compress&cs=tinysrgb&w=1920') center/cover no-repeat;
    filter: brightness(0.2);
    z-index: -2;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.8), rgba(0,0,0,0.7), rgba(0,0,0,0.9));
    z-index: -1;
  }

  .hero-glow {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(168,85,247,0.08), transparent 70%);
    z-index: -1;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 40rem;
  }

  .hero-logo {
    margin: 0 auto 2rem;
    opacity: 0.85;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: white;
  }

  @media (min-width: 768px) {
    .hero-title { font-size: 2.75rem; }
  }

  .hero-subtitle {
    font-size: 1.125rem;
    font-weight: 300;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.5rem;
  }

  .hero-ctas {
    margin-top: 2.5rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .action-link {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 300;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    transition: all 0.2s;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .action-link:hover {
    color: white;
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.2);
  }

  /* CTA buttons */
  .cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.25s;
  }

  .cta-primary {
    background: var(--color-accent);
    color: white;
  }

  .cta-primary:hover {
    background: var(--color-accent-2);
  }

  .cta-secondary {
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--color-text-muted);
  }

  .cta-secondary:hover {
    border-color: rgba(255,255,255,0.3);
    color: white;
    background: rgba(255,255,255,0.05);
  }

  /* Chapel preview */
  .chapel-preview {
    background: var(--color-surface);
  }

  .chapel-card {
    text-align: center;
    max-width: 36rem;
    margin: 0 auto;
    padding: 3rem 0;
  }

  .chapel-title {
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 1.5rem;
    color: white;
  }

  @media (min-width: 768px) {
    .chapel-title { font-size: 2.25rem; }
  }

  .chapel-text {
    margin-bottom: 2rem;
  }

  .chapel-text p {
    font-size: 1rem;
    font-weight: 300;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .chapel-emphasis {
    font-weight: 500 !important;
    color: var(--color-accent) !important;
  }

  /* Why section */
  .why-matters {
    background: var(--color-bg);
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 400;
    text-align: center;
    margin-bottom: 1.5rem;
    color: white;
  }

  @media (min-width: 768px) {
    .section-title { font-size: 2.25rem; }
  }

  .section-lead {
    font-size: 1rem;
    font-weight: 300;
    color: var(--color-text-muted);
    text-align: center;
    max-width: 40rem;
    margin: 0 auto 1rem;
  }

  .features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .features { grid-template-columns: repeat(3, 1fr); }
  }

  .feature {
    text-align: center;
    padding: 2rem 1.5rem;
    border-radius: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .feature-icon {
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .feature-title {
    font-size: 1.125rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
    color: white;
  }

  .feature-desc {
    font-size: 0.9375rem;
    font-weight: 300;
    color: var(--color-text-muted);
  }

  /* Beginning section */
  .the-beginning {
    background: var(--color-surface);
  }

  .beginning-content {
    text-align: center;
    max-width: 36rem;
    margin: 0 auto;
  }

  .beginning-title {
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 2rem;
    color: white;
  }

  .beginning-quote {
    font-size: 1.5rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    padding: 0;
  }

  @media (min-width: 768px) {
    .beginning-quote { font-size: 1.75rem; }
  }

  .beginning-text {
    font-size: 1.0625rem;
    font-weight: 300;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .beginning-content .cta {
    margin-top: 1.5rem;
  }

  /* Support section */
  .support-section {
    background: var(--color-bg);
  }

  .support-list {
    list-style: none;
    max-width: 32rem;
    margin: 1.5rem auto 2rem;
    text-align: left;
  }

  .support-list li {
    font-size: 0.9375rem;
    font-weight: 300;
    color: var(--color-text-muted);
    padding: 0.5rem 0;
    padding-left: 1.25rem;
    position: relative;
  }

  .support-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .support-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }

  /* Bottom */
  .bottom-logo-section {
    padding-bottom: 6rem;
  }

  .bottom-logo {
    opacity: 0.5;
    margin-bottom: 1rem;
  }

  .bottom-stay {
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>