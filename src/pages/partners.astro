---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Partners — Don't Lose Your Way" description="Help this project reach someone who needs it. Partnerships, grants, and collaboration.">

  <section class="partners-hero">
    <div class="container">
      <h1>Partners</h1>
      <p class="partners-subtitle">Help this project reach someone who needs it.</p>
    </div>
  </section>

  <section class="section">
    <div class="container partners-body">

      <div class="partners-intro">
        <p>Don't Lose Your Way welcomes partnerships, grants, sponsorships, and creative contributions from organizations and individuals who share our mission: ensuring no one faces their quiet moments alone.</p>
      </div>

      <div class="partners-opportunities">
        <div class="opp-card">
          <h3>Mental Health Organizations</h3>
          <p>Partner with us to extend crisis support and emotional resources to underserved communities.</p>
        </div>
        <div class="opp-card">
          <h3>Grants & Funding</h3>
          <p>Help us sustain and scale this free platform so it remains accessible to everyone who needs it.</p>
        </div>
        <div class="opp-card">
          <h3>Sponsorships</h3>
          <p>Aligned organizations can sponsor specific features, content, or community outreach programs.</p>
        </div>
        <div class="opp-card">
          <h3>Creative Contributions</h3>
          <p>Musicians, writers, and artists can contribute to the Chapel, Journal, and Podcast.</p>
        </div>
      </div>

      <div id="contact" class="contact-section">
        <h2>Get In Touch</h2>
        <p>Interested in partnering? We'd love to hear from you.</p>
        <form id="contactForm" class="contact-form">
          <label for="contactName" class="sr-only">Name</label>
          <input type="text" id="contactName" name="name" placeholder="Your name" class="form-input" required />
          
          <label for="contactEmail" class="sr-only">Email</label>
          <input type="email" id="contactEmail" name="email" placeholder="Email address" class="form-input" required />
          
          <label for="contactOrg" class="sr-only">Organization</label>
          <input type="text" id="contactOrg" name="organization" placeholder="Organization (optional)" class="form-input" />
          
          <label for="contactMessage" class="sr-only">Message</label>
          <textarea id="contactMessage" name="message" rows="5" placeholder="Tell us about your interest in partnering..." class="form-input form-textarea" required></textarea>
          
          <button type="submit" class="cta">Send Message</button>
        </form>
        <div id="contactSuccess" class="contact-success hidden">
          <h3>Thank you.</h3>
          <p>We'll be in touch soon.</p>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  .partners-hero {
    padding: 8rem 0 2rem;
    text-align: center;
  }

  .partners-hero h1 {
    font-size: 2.5rem;
    font-weight: 300;
    margin-bottom: 0.75rem;
  }

  .partners-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .partners-body {
    max-width: 44rem;
  }

  .partners-intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .partners-intro p {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.75;
  }

  .partners-opportunities {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 640px) {
    .partners-opportunities { grid-template-columns: repeat(2, 1fr); }
  }

  .opp-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .opp-card h3 {
    font-size: 1.0625rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .opp-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .contact-section {
    text-align: center;
    padding: 2rem 0;
  }

  .contact-section h2 {
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .contact-section > p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .contact-form {
    max-width: 28rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-input {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: white;
    transition: border-color 0.2s;
  }

  .form-input::placeholder { color: rgba(255,255,255,0.3); }
  .form-input:focus { outline: none; border-color: var(--color-accent); }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    background: var(--color-accent);
    color: white;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: all 0.25s;
  }

  .cta:hover { background: var(--color-accent-2); }

  .contact-success {
    padding: 2rem;
    background: rgba(168,85,247,0.05);
    border: 1px solid rgba(168,85,247,0.15);
    border-radius: 0.75rem;
  }

  .contact-success h3 {
    color: var(--color-accent);
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .contact-success p {
    color: var(--color-text-muted);
  }

  .hidden { display: none; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
</style>

<script>
  const form = document.getElementById('contactForm');
  const success = document.getElementById('contactSuccess');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.classList.add('hidden');
    success.classList.remove('hidden');
  });
</script>